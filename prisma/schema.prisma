generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  email               String   @unique
  password            String
  profile_picture_url String?
  links               Link[]

  @@map("users")
}

model Link {
  id      String @id @default(uuid())
  title   String
  url     String
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("links")
}
